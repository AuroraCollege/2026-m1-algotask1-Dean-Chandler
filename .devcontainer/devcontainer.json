{
  "name": "Python 3.12",
  "image": "mcr.microsoft.com/devcontainers/python:3.12",

  "customizations": {
    "vscode": {
      "settings": {
        // Dark mode
        "workbench.colorTheme": "Default Dark Modern",
        "workbench.preferredDarkColorTheme": "Default Dark Modern",

        // Kill all AI / Copilot features
        "github.copilot.enable": { "*": false },
        "github.copilot.editor.enableAutoCompletions": false,
        "github.copilot.inlineSuggest.enable": false,
        "github.copilot.chat.enabled": false,
        "editor.inlineSuggest.enabled": false,

        // Disable IntelliCode & similar
        "vsintellicode.features.python.deepLearning": "disabled",
        "vsintellicode.modify.editor.suggestSelection": "none",

        // Lightweight editor tweaks
        "editor.minimap.enabled": false,
        "extensions.ignoreRecommendations": true,
        "telemetry.telemetryLevel": "off"
      },

      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance"
      ]
    }
  },

  // Nothing to forward by default - add ports here as needed
  "forwardPorts": [],

  "postCreateCommand": "python --version"
}
